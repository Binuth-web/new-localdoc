	"item": [
		{
			"name": "Auth Flow",
			"item": [
				{
					"name": "Login - Valid User",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"pm.test(\"Response is JSON\", function () {",
									"    pm.response.to.be.json;",
									"});",
									"var jsonData = pm.response.json();",
									"pm.test(\"Login should be successful or fail gracefully\", function () {",
									"    pm.expect(jsonData.status).to.be.oneOf(['success', 'error']);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "username",
									"value": "admin@medconnect",
									"type": "text"
								},
								{
									"key": "password",
									"value": "admin123",
									"type": "text"
								},
								{
									"key": "portal",
									"value": "admin",
									"type": "text"
								}
							]
						},
						"url": {
							"raw": "{{base_url}}/login.php",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"login.php"
							]
						}
					},
					"response": []
				},
